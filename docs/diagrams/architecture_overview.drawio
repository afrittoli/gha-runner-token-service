        <mxCell id="m2m-note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F8E9;strokeColor=#558B2F;strokeWidth=1;fontSize=9;align=left;fontColor=#333;spacingLeft=6;spacingRight=6;" value="&lt;b&gt;M2M Auth Flow&lt;/b&gt;&lt;br&gt;1. Pipeline calls Auth0 /oauth/token&lt;br&gt;2. Auth0 Action injects &quot;team&quot; claim&lt;br&gt;3. JWT sent as Bearer to GHARTS&lt;br&gt;4. Backend validates JWT, looks up OAuthClient&lt;br&gt;5. Resolves team, checks label policy &amp; quota&lt;br&gt;6. Returns JIT config from GitHub" vertex="1">
          <mxGeometry height="140" width="280" x="60" y="560" as="geometry" />
        </mxCell>
