# GitHub App Configuration
GITHUB_APP_ID=123456
GITHUB_APP_INSTALLATION_ID=12345678
GITHUB_APP_PRIVATE_KEY_PATH=./github-app-private-key.pem
GITHUB_ORG=your-organization

# OIDC Configuration
OIDC_ISSUER=https://your-oidc-provider.com
OIDC_AUDIENCE=runner-token-service
OIDC_JWKS_URL=https://your-oidc-provider.com/.well-known/jwks.json

# Database
DATABASE_URL=sqlite:///./runner_service.db

# Service Configuration
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000

# Logging Configuration
# Application log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Enable detailed tracing in access logs (headers, request/response payloads)
ACCESS_LOG_TRACING=false
# Directory for log files (access.log and app.log)
LOG_DIR=logs

# Security
API_KEY_HEADER=X-API-Key
ENABLE_OIDC_AUTH=true

# Sync Configuration
# DEPRECATED: In-process sync is deprecated. Use dedicated sync worker (app/worker.py) instead.
# Only enable for development/testing. For production, set SYNC_ENABLED=false and deploy sync worker.
SYNC_ENABLED=false
SYNC_INTERVAL_SECONDS=120
SYNC_ON_STARTUP=false
