# OIDC Configuration for Local Development
# Copy this to .env.local and fill in your values
#
# NOTE: In production/Kubernetes deployments, configuration is injected at runtime
# via ConfigMap and Secret. These environment variables are only used for local
# development when running `npm run dev` without containers.

# Auth0 or other OIDC provider domain
VITE_OIDC_AUTHORITY=https://your-tenant.auth0.com

# Client ID from your OIDC provider
VITE_OIDC_CLIENT_ID=your-client-id

# Redirect URI after login (must be registered with OIDC provider)
# Development: http://localhost:5173/app/callback
VITE_OIDC_REDIRECT_URI=http://localhost:5173/app/callback

# Redirect URI after logout
# Development: http://localhost:5173/app
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/app

# API Audience (must match backend OIDC_AUDIENCE)
VITE_OIDC_AUDIENCE=runner-token-service

# API base URL (optional, defaults to same origin)
# For local development with separate backend:
# VITE_API_BASE_URL=http://localhost:8000
